# =============================================================================
# PIEA - Public Information Exposure Analyzer
# Environment Variables Template
# Copy this file to .env and fill in the values
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://piea:password@localhost:5432/piea

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# --- Logging ---
LOG_LEVEL=INFO

# --- API Keys (Phase 1+) ---
HIBP_API_KEY=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ENGINE_ID=
GITHUB_TOKEN=
HUNTER_API_KEY=
STEAM_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# --- Scan Limits ---
SCAN_MAX_DEPTH=3
SCAN_TIMEOUT_SECONDS=120
SCAN_MAX_NODES=500
SCAN_RATE_LIMIT_PER_HOUR=10

# --- Cache TTL (seconds) ---
CACHE_TTL_BREACH=86400
CACHE_TTL_PROFILE=3600
